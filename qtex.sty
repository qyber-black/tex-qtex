% LOF/LOT/LOA writefile patch (guarded allocation; skipped for slides)
\ifqtex@slides\else
\@ifundefined{tf@lof}{\newwrite\tf@lof}{}%
\@ifundefined{tf@lot}{\newwrite\tf@lot}{}%
\@ifundefined{tf@loa}{\newwrite\tf@loa}{}%
\long\def\qtex@writelist#1#2{%
  \@ifundefined{qtex@opened@#1}{%
    \immediate\openout\csname tf@#1\endcsname\jobname.#1
    \expandafter\gdef\csname qtex@opened@#1\endcsname{}%
  }{}%
  \immediate\write\csname tf@#1\endcsname{\unexpanded{#2}}%
}
\def\qtex@write@lof#1{\qtex@writelist{lof}{#1}}
\def\qtex@write@lot#1{\qtex@writelist{lot}{#1}}
\def\qtex@write@loa#1{\qtex@writelist{loa}{#1}}
\long\def\qtex@writefile#1#2{%
  \edef\qtex@write@arg{#1}%
  \ifx\qtex@write@arg\qtex@lofstr
    \qtex@write@lof{#2}%
  \else
    \ifx\qtex@write@arg\qtex@lotstr
      \qtex@write@lot{#2}%
    \else
      \ifx\qtex@write@arg\qtex@loastr
        \qtex@write@loa{#2}%
      \else
        \@gobbletwo{#1}{#2}%
      \fi
    \fi
  \fi
}
\def\qtex@lofstr{lof}\def\qtex@lotstr{lot}\def\qtex@loastr{loa}
\patchcmd{\document}{\let\@writefile\@gobbletwo}{\let\@writefile\qtex@writefile}{}{}
\fi

