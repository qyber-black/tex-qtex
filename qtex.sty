}

% ------------------------------------------------------------------------------
% Font configuration (sans default, serif, hacker)
% ------------------------------------------------------------------------------
\ifPDFTeX
  \ifqtex@font@sans
    \RequirePackage[default]{sourcesanspro}%
    \RequirePackage{newtxmath}%
    \renewcommand{\familydefault}{\sfdefault}%
  \fi
  \ifqtex@font@serif
    \RequirePackage[default]{sourceserifpro}%
    \RequirePackage{newtxmath}%
  \fi
  \ifqtex@font@hacker
    \RequirePackage{inconsolata}%
    \RequirePackage{newtxmath}%
    \renewcommand{\familydefault}{\ttdefault}%
  \fi
\else
  \RequirePackage{fontspec}%
  \defaultfontfeatures{Ligatures=TeX}%
  \ifluatex
    \ifqtex@noobfuscate \else
      \IfFileExists{fonts/obfuscate-perm.lua}{%
        \directlua{%
          local perm = dofile("fonts/obfuscate-perm.lua")
          local PUA = 0xE000
          luatexbase.add_to_callback("luaotfload.patch_font", function(tfmdata)
            if not tfmdata or not tfmdata.characters then return end
            if not tfmdata.characters[PUA] then return end
            if tfmdata.characters[0x41] then return end
            tfmdata.embedding = "full"
            tfmdata.qtex_obfuscated = true
            for c = 0, 255 do
              local src = PUA + perm[c]
              if tfmdata.characters[src] then
                tfmdata.characters[c] = tfmdata.characters[src]
              end
            end
            for c = 0, 255 do
              local slot = PUA + perm[c]
              if tfmdata.characters[slot] then
                tfmdata.characters[slot].unicode = slot
                tfmdata.characters[slot].tounicode = slot
              end
            end
          end, "qtex_obfuscate_full_embed")
        }%
        \AtBeginDocument{%
          \directlua{%
            local perm = dofile("fonts/obfuscate-perm.lua")
            local PUA = 0xE000
            local hlist_id = node.id("hlist")
            local vlist_id = node.id("vlist")
            local function obfuscate_glyphs(head)
              for n in node.traverse(head) do
                if n.id == node.id("glyph") then
                  local tfm = fonts.hashes.identifiers[n.font]
                  if tfm and tfm.qtex_obfuscated and n.char >= 0 and n.char <= 255 and perm[n.char] then
                    n.char = PUA + perm[n.char]
                  end
                elseif (n.id == hlist_id or n.id == vlist_id) and n.head then
                  obfuscate_glyphs(n.head)
                end
              end
              return head
            end
            luatexbase.add_to_callback("pre_linebreak_filter", obfuscate_glyphs, "qtex_obfuscate")
            luatexbase.add_to_callback("pre_output_filter", obfuscate_glyphs, "qtex_obfuscate")
          }%
        }%
      }{%
        \PackageError{qtex}{%
          Obfuscation requires fonts/obfuscate-perm.lua.\MessageBreak
          Generate it with the build script (see README).%
        }{Then re-run LaTeX.}%
      }%
    \fi
  \else
    \ifqtex@noobfuscate \else
      \PackageWarningNoLine{qtex}{Obfuscation is LuaLaTeX-only; using normal fonts}%
    \fi
  \fi
  \ifqtex@font@sans
    \ifluatex \ifqtex@noobfuscate \else
      \IfFileExists{fonts/sans-obfuscated.otf}{%
        \def\qtex@obf@opts{Path=fonts/,Extension=.otf}%
        \IfFileExists{fonts/sans-obfuscated-Bold.otf}{\g@addto@macro\qtex@obf@opts{,BoldFont=sans-obfuscated-Bold}}{}%
        \IfFileExists{fonts/sans-obfuscated-Italic.otf}{\g@addto@macro\qtex@obf@opts{,ItalicFont=sans-obfuscated-Italic}}{}%
        \IfFileExists{fonts/sans-obfuscated-BoldItalic.otf}{\g@addto@macro\qtex@obf@opts{,BoldItalicFont=sans-obfuscated-BoldItalic}}{}%
        \setmainfont{sans-obfuscated}[\qtex@obf@opts]%
        \setsansfont{sans-obfuscated}[\qtex@obf@opts]%
        \setmonofont{sans-obfuscated}[\qtex@obf@opts]%
        \renewcommand{\labelitemi}{\normalfont\char"B7}%
        \renewcommand{\labelitemii}{\normalfont\char"B7}%
        \renewcommand{\labelitemiii}{\normalfont\char"B7}%
        \renewcommand{\labelitemiv}{\normalfont\char"B7}%
      }{%
        \PackageError{qtex}{Obfuscation requires fonts/sans-obfuscated.otf. Generate with build script.}{}%
      }%
    \fi \fi
    \ifqtex@noobfuscate
      \IfFontExistsTF{Source Sans Pro}{%
        \setmainfont{Source Sans Pro}%
        \setsansfont{Source Sans Pro}%
        \IfFontExistsTF{Source Code Pro}{\setmonofont{Source Code Pro}[Scale=MatchLowercase]}{\setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]}%
      }{%
        \setmainfont{TeX Gyre Heros}%
        \setsansfont{TeX Gyre Heros}%
        \setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]%
      }%
    \else \ifluatex \else
      \IfFontExistsTF{Source Sans Pro}{%
        \setmainfont{Source Sans Pro}%
        \setsansfont{Source Sans Pro}%
        \IfFontExistsTF{Source Code Pro}{\setmonofont{Source Code Pro}[Scale=MatchLowercase]}{\setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]}%
      }{%
        \setmainfont{TeX Gyre Heros}%
        \setsansfont{TeX Gyre Heros}%
        \setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]%
      }%
    \fi \fi
  \fi
  \ifqtex@font@serif
    \ifluatex \ifqtex@noobfuscate \else
      \IfFileExists{fonts/serif-obfuscated.otf}{%
        \def\qtex@obf@opts{Path=fonts/,Extension=.otf}%
        \IfFileExists{fonts/serif-obfuscated-Bold.otf}{\g@addto@macro\qtex@obf@opts{,BoldFont=serif-obfuscated-Bold}}{}%
        \IfFileExists{fonts/serif-obfuscated-Italic.otf}{\g@addto@macro\qtex@obf@opts{,ItalicFont=serif-obfuscated-Italic}}{}%
        \IfFileExists{fonts/serif-obfuscated-BoldItalic.otf}{\g@addto@macro\qtex@obf@opts{,BoldItalicFont=serif-obfuscated-BoldItalic}}{}%
        \setmainfont{serif-obfuscated}[\qtex@obf@opts]%
        \setsansfont{serif-obfuscated}[\qtex@obf@opts]%
        \setmonofont{serif-obfuscated}[\qtex@obf@opts]%
        \renewcommand{\labelitemi}{\normalfont\char"B7}%
        \renewcommand{\labelitemii}{\normalfont\char"B7}%
        \renewcommand{\labelitemiii}{\normalfont\char"B7}%
        \renewcommand{\labelitemiv}{\normalfont\char"B7}%
      }{%
        \PackageError{qtex}{Obfuscation requires fonts/serif-obfuscated.otf. Generate with build script.}{}%
      }%
    \fi \fi
    \ifqtex@noobfuscate
      \IfFontExistsTF{Source Serif Pro}{%
        \setmainfont{Source Serif Pro}%
        \setsansfont{Source Sans Pro}[Scale=MatchLowercase]%
        \IfFontExistsTF{Source Code Pro}{\setmonofont{Source Code Pro}[Scale=MatchLowercase]}{\setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]}%
      }{%
        \setmainfont{TeX Gyre Termes}%
        \setsansfont{TeX Gyre Heros}[Scale=MatchLowercase]%
        \setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]%
      }%
    \else \ifluatex \else
      \IfFontExistsTF{Source Serif Pro}{%
        \setmainfont{Source Serif Pro}%
        \setsansfont{Source Sans Pro}[Scale=MatchLowercase]%
        \IfFontExistsTF{Source Code Pro}{\setmonofont{Source Code Pro}[Scale=MatchLowercase]}{\setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]}%
      }{%
        \setmainfont{TeX Gyre Termes}%
        \setsansfont{TeX Gyre Heros}[Scale=MatchLowercase]%
        \setmonofont{TeX Gyre Cursor}[Scale=MatchLowercase]%
      }%
    \fi \fi
  \fi
  \ifqtex@font@hacker
    \ifluatex \ifqtex@noobfuscate \else
      \IfFileExists{fonts/hacker-obfuscated.otf}{%
        \def\qtex@obf@opts{Path=fonts/,Extension=.otf}%
        \IfFileExists{fonts/hacker-obfuscated-Bold.otf}{\g@addto@macro\qtex@obf@opts{,BoldFont=hacker-obfuscated-Bold}}{}%
        \IfFileExists{fonts/hacker-obfuscated-Italic.otf}{\g@addto@macro\qtex@obf@opts{,ItalicFont=hacker-obfuscated-Italic}}{}%
        \IfFileExists{fonts/hacker-obfuscated-BoldItalic.otf}{\g@addto@macro\qtex@obf@opts{,BoldItalicFont=hacker-obfuscated-BoldItalic}}{}%
        \setmainfont{hacker-obfuscated}[\qtex@obf@opts]%
        \setsansfont{hacker-obfuscated}[\qtex@obf@opts]%
        \setmonofont{hacker-obfuscated}[\qtex@obf@opts]%
        \renewcommand{\labelitemi}{\normalfont\char"B7}%
        \renewcommand{\labelitemii}{\normalfont\char"B7}%
        \renewcommand{\labelitemiii}{\normalfont\char"B7}%
        \renewcommand{\labelitemiv}{\normalfont\char"B7}%
      }{%
        \PackageError{qtex}{Obfuscation requires fonts/hacker-obfuscated.otf. Generate with build script.}{}%
      }%
    \fi \fi
    \ifqtex@noobfuscate
      \IfFontExistsTF{Inconsolata}{%
        \setmainfont{Inconsolata}%
        \setsansfont{Inconsolata}%
        \setmonofont{Inconsolata}%
      }{\setmainfont{Fira Mono}\setsansfont{Fira Mono}\setmonofont{Fira Mono}}%
    \else \ifluatex \else
      \PackageWarning{qtex}{Obfuscation is LuaLaTeX-only; using normal hacker font.}%
      \IfFontExistsTF{Inconsolata}{%
        \setmainfont{Inconsolata}%
        \setsansfont{Inconsolata}%
        \setmonofont{Inconsolata}%
      }{\setmainfont{Fira Mono}\setsansfont{Fira Mono}\setmonofont{Fira Mono}}%
    \fi \fi
  \fi
  \RequirePackage{unicode-math}%
  \setmathfont{Latin Modern Math}[Scale=MatchLowercase]%
\fi

% ------------------------------------------------------------------------------
% Layout: single default; onehalfspacing / linespread options
% (disabled for slides so beamer keeps control of spacing).
% ------------------------------------------------------------------------------
\ifqtex@slides
  % Slides: use beamer's default spacing (no setspace).
\else
  \ifqtex@onehalfspacing
    \onehalfspacing
  \else
    \ifqtex@linespread
      \linespread{\qtex@linespreadval}%
    \else
      \singlespacing
    \fi
  \fi
\fi
\ifqtex@justify\else \RaggedRight\fi
\emergencystretch=3em

