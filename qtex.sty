\newcommand{\qtex@resolvelicense}{%
  \edef\qtex@lic@curid{\qtex@licenseid}%
  \edef\qtex@lic@cstest{qtex@lic@\qtex@lic@curid}%
  \expandafter\@ifundefined\expandafter{\qtex@lic@cstest}{%
    \gdef\qtex@lic@name{SPDX: \qtex@licenseid}%
    \gdef\qtex@lic@url{https://spdx.org/licenses/\qtex@licenseid.html}%
  }{%
    \expandafter\qtex@setlicfrompair\csname qtex@lic@\qtex@lic@curid\endcsname
  }%
}

\AtBeginDocument{%
  \ifqtex@license
    \InputIfFileExists{qtex-licenses.tex}{}{}%
  \fi
}

% ------------------------------------------------------------------------------
% Section/subsection formatting (titlesec) -- shared by qarticle and qbook
% Tighter spacing for compact, Tufte-informed vertical rhythm.
% (Skipped for slides: beamer handles its own sectioning.)
% ------------------------------------------------------------------------------
\ifqtex@slides\else
\RequirePackage{titlesec}%
\ifqtex@italic
  \titleformat{\section}[hang]{\normalfont\Large\itshape}{\thesection}{1em}{}%
  \titleformat{\subsection}[hang]{\normalfont\large\itshape}{\thesubsection}{1em}{}%
  \titleformat{\subsubsection}[hang]{\normalfont\normalsize\itshape}{\thesubsubsection}{1em}{}%
\else
  \titleformat{\section}[hang]{\normalfont\Large\bfseries}{\thesection}{1em}{}%
  \titleformat{\subsection}[hang]{\normalfont\large\bfseries}{\thesubsection}{1em}{}%
  \titleformat{\subsubsection}[hang]{\normalfont\normalsize\bfseries}{\thesubsubsection}{1em}{}%
\fi
\titlespacing*{\section}{0pt}{2.5ex plus 0.8ex minus 0.3ex}{1.2ex plus 0.2ex}%
\titlespacing*{\subsection}{0pt}{2.0ex plus 0.6ex minus 0.2ex}{0.8ex plus 0.1ex}%
\titlespacing*{\subsubsection}{0pt}{1.5ex plus 0.5ex minus 0.2ex}{0.5ex plus 0.1ex}%
\ifqtex@parindent
  \let\qtex@orig@afterheading\@afterheading
  \renewcommand{\@afterheading}{%
    \qtex@orig@afterheading
    \noindent
  }
\fi
\fi

% ------------------------------------------------------------------------------
% Page styles (fancyhdr) -- shared plain and empty styles for book and article.
% Chapter-specific styles (plainchapter, chapter) remain in qbook.cls.
% (Skipped for slides.)
% ------------------------------------------------------------------------------
\ifqtex@slides\else
\RequirePackage{fancyhdr}
\newlength{\qtex@headruleheight}
\setlength{\qtex@headruleheight}{0.4pt}
\def\qtex@dt@book{book}%
\ifx\qtex@doctype\qtex@dt@book
  \setlength{\headheight}{32pt}%
  \addtolength{\topmargin}{-16pt}%
\else
  \setlength{\headheight}{15pt}%
\fi

\fancypagestyle{empty}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \ifqtex@twoside
    \fancyhead[LE,RO]{\thepage}%
    \fancyhead[LO,RE]{\textls[50]{\scshape\leftmark}}%
  \else
    \fancyhead[L]{\textls[50]{\scshape\leftmark}}%
    \fancyhead[R]{\thepage}%
  \fi
  \renewcommand{\headrulewidth}{\qtex@headruleheight}%
}
\pagestyle{plain}
\fi

% ------------------------------------------------------------------------------
% MakeUppercase suppression in running heads (Tufte: prefer small caps, not
% ALL CAPS). Applied at \AtBeginDocument so base-class definitions exist.
% ------------------------------------------------------------------------------
\ifqtex@slides\else
\AtBeginDocument{%
  \def\qtex@dt@book{book}%
  \ifx\qtex@doctype\qtex@dt@book
    \@ifundefined{bibsection}{}{%
      \renewcommand{\bibsection}{\chapter*{\bibname\@mkboth{\bibname}{\bibname}}}%
    }%
    \@ifundefined{thebibliography}{}{%
      \patchcmd{\thebibliography}{\MakeUppercase\bibname}{\bibname}{}{}%
      \patchcmd{\thebibliography}{\MakeUppercase\bibname}{\bibname}{}{}%
    }%
  \else
    \@ifundefined{bibsection}{}{%
      \renewcommand{\bibsection}{\section*{\refname\@mkboth{\refname}{\refname}}}%
    }%
    \@ifundefined{thebibliography}{}{%
      \patchcmd{\thebibliography}{\MakeUppercase\refname}{\refname}{}{}%
      \patchcmd{\thebibliography}{\MakeUppercase\refname}{\refname}{}{}%
    }%
  \fi
}
\fi

% ------------------------------------------------------------------------------
% Bibliography helper (\bib): shared style selection and license output.
% Classes call \qtex@bib@setup then add class-specific structure.
% ------------------------------------------------------------------------------
\newcommand{\qtex@bib@selectstyle}{%
  \ifqtex@cite@harvard
    \bibliographystyle{agsm}%
  \else
    \bibliographystyle{plainnat}%
  \fi
}
\renewcommand{\bibname}{References}

\microtypesetup{final,protrusion=true,nopatch=footnote}%
\ifXeTeX\else \microtypesetup{expansion=true}\fi

\hypersetup{
  unicode=true,
  breaklinks=true,
  colorlinks=true,
  linkcolor=DarkBlue,
  citecolor=DarkGreen,
  urlcolor=DarkGreen,
  filecolor=DarkBlue,
  menucolor=DarkBlue
}
\let\qtex@orig@href\href
\renewcommand{\href}[2]{%
  \qtex@orig@href{#1}{{\color{DarkBlue}#2}}%
}
\def\UrlFont{\ttfamily\color{DarkGreen}}%

\makeatother
