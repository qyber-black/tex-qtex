\newcommand{\epigraph}[2]{%
  \par\vspace{0.8\baselineskip}%
  \noindent\hfill\parbox{0.6\textwidth}{\raggedleft\small
    #1\par\vspace{0.3ex}%
    \textls[50]{\scshape #2}%
  }%
